# Generated by depends/Makefile from toolchain.cmake.in. Scopes capnp discovery only:
# sets CapnProto_DIR so find_package(CapnProto) resolves the hermetic 1.4.0 from the
# depends prefix, while Boost/OpenSSL/libevent/zeromq resolve from the system.
# The rest of the node build continues to use system libraries (no blanket prefix).
set(CapnProto_DIR "${CMAKE_CURRENT_LIST_DIR}/lib/cmake/CapnProto" CACHE PATH "")

set(ipc_packages @ipc_packages@)
if("${ipc_packages}" STREQUAL "")
  set(ENABLE_IPC OFF CACHE BOOL "")
else()
  set(ENABLE_IPC ON CACHE BOOL "")
  set(MPGEN_EXECUTABLE "${CMAKE_CURRENT_LIST_DIR}/native/bin/mpgen" CACHE FILEPATH "")
  set(CAPNP_EXECUTABLE "${CMAKE_CURRENT_LIST_DIR}/native/bin/capnp" CACHE FILEPATH "")
  set(CAPNPC_CXX_EXECUTABLE "${CMAKE_CURRENT_LIST_DIR}/native/bin/capnpc-c++" CACHE FILEPATH "")
endif()
